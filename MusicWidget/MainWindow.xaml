<Window x:Class="MusicWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="MusicWidget" 
        Height="210" Width="480"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid Margin="10">
        <materialDesign:Card x:Name="MainCard" 
                             materialDesign:ElevationAssist.Elevation="Dp8"
                             UniformCornerRadius="24"
                             Background="Transparent">

            <materialDesign:Card.ContextMenu>
                <ContextMenu Style="{StaticResource MaterialDesignContextMenu}" 
                             Background="Transparent" BorderThickness="0" HasDropShadow="False" Padding="0">
                    <ContextMenu.Template>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{DynamicResource MaterialDesignPaper}"
                                    CornerRadius="12" Margin="12"
                                    BorderThickness="1" BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    RenderTransformOrigin="0.2,0.2" Opacity="0">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.3" Direction="270" Color="Black"/>
                                </Border.Effect>
                                <Grid IsSharedSizeScope="True">
                                    <ItemsPresenter Margin="0,8" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Grid>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.8" To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.8" To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                        </ControlTemplate>
                    </ContextMenu.Template>
                    <MenuItem Click="MenuSettings_Click">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <materialDesign:PackIcon Kind="SettingsOutline" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0" Opacity="0.8"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <Separator Margin="12,4" Opacity="0.4"/>
                    <MenuItem Click="MenuExit_Click">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <materialDesign:PackIcon Kind="ExitToApp" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#FFD32F2F"/>
                                <TextBlock Text="Exit" VerticalAlignment="Center" FontSize="14" Foreground="#FFD32F2F" FontWeight="Bold"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                </ContextMenu>
            </materialDesign:Card.ContextMenu>

            <Border x:Name="CardInnerBorder" CornerRadius="24" ClipToBounds="True" Background="#FF0B2D44">
                <Grid>
                    <Image x:Name="BlurBgImage" Stretch="UniformToFill" Margin="-30,-30,0,-30" HorizontalAlignment="Left" Width="360" Opacity="0"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.CacheMode>
                            <BitmapCache EnableClearType="False" RenderAtScale="1"/>
                        </Image.CacheMode>
                        <Image.Effect>
                            <BlurEffect Radius="80" KernelType="Gaussian" RenderingBias="Quality"/>
                        </Image.Effect>
                        <Image.OpacityMask>
                            <RadialGradientBrush x:Name="BgFadeMask" Center="0,0.5" GradientOrigin="0,0.5" RadiusX="0" RadiusY="0">
                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                <GradientStop Color="#E6FFFFFF" Offset="0.2"/>
                                <GradientStop Color="#B3FFFFFF" Offset="0.45"/>
                                <GradientStop Color="#66FFFFFF" Offset="0.75"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </RadialGradientBrush>
                        </Image.OpacityMask>
                    </Image>

                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid x:Name="TrackInfoContainer" Grid.Column="0" Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" x:Name="CoverContainer" Width="140" Height="140" VerticalAlignment="Center" Background="Transparent">
                                <Grid x:Name="CoverBgLayer">
                                    <Grid>
                                        <Grid.Clip>
                                            <RectangleGeometry RadiusX="16" RadiusY="16" Rect="0,0,140,140"/>
                                        </Grid.Clip>
                                        <Rectangle Fill="#FF1E1E1E" />
                                        <Image x:Name="CoverImage" Stretch="UniformToFill" Margin="-16" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Grid>
                                    <Rectangle x:Name="CoverSpotlight" RadiusX="16" RadiusY="16" IsHitTestVisible="False" Opacity="0">
                                        <Rectangle.Fill>
                                            <RadialGradientBrush RadiusX="0.6" RadiusY="0.6">
                                                <GradientStop Color="#50FFFFFF" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </Grid>
                            </Grid>

                            <StackPanel Grid.Column="1" Margin="24,4,0,0" VerticalAlignment="Top">
                                <TextBlock x:Name="TitleText" Text="未在播放" 
                                           Style="{StaticResource MaterialDesignHeadlineSmallTextBlock}"
                                           Foreground="#FFFFFFFF" TextTrimming="CharacterEllipsis" FontWeight="Bold"/>
                                <TextBlock x:Name="ArtistText" Text="无媒体会话" 
                                           Style="{StaticResource MaterialDesignBodyMediumTextBlock}" FontSize="15"
                                           Foreground="#B3FFFFFF" TextWrapping="Wrap" MaxHeight="45" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="166,0,0,7">
                            <Grid x:Name="PrevContainer" Width="64" Height="56" Margin="0,0,12,0" Background="Transparent">
                                <Grid x:Name="PrevBgLayer">
                                    <Button x:Name="BtnPrev" FocusVisualStyle="{x:Null}" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ElevationAssist.Elevation="Dp0" Padding="0" Width="64" Height="56" Margin="0" materialDesign:ButtonAssist.CornerRadius="28" BorderThickness="0" Background="#FF9BC8EB" Click="BtnPrev_Click"/>
                                    <Rectangle x:Name="PrevSpotlight" RadiusX="28" RadiusY="28" IsHitTestVisible="False" Opacity="0">
                                        <Rectangle.Fill>
                                            <RadialGradientBrush RadiusX="0.7" RadiusY="0.7">
                                                <GradientStop Color="#60FFFFFF" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </Grid>
                                <Grid x:Name="PrevIcon3DLayer" IsHitTestVisible="False">
                                    <materialDesign:PackIcon x:Name="PrevIcon" Kind="SkipPrevious" Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                        <materialDesign:PackIcon.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform/>
                                                <TranslateTransform/>
                                            </TransformGroup>
                                        </materialDesign:PackIcon.RenderTransform>
                                    </materialDesign:PackIcon>
                                </Grid>
                            </Grid>

                            <Grid x:Name="PlayContainer" Width="68" Height="68" Margin="0,0,12,0" Background="Transparent">
                                <Grid x:Name="PlayBgLayer">
                                    <Button x:Name="BtnPlayPause" FocusVisualStyle="{x:Null}" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ElevationAssist.Elevation="Dp0" Padding="0" Width="68" Height="68" Margin="0" materialDesign:ButtonAssist.CornerRadius="34" BorderThickness="0" Background="#FFDCC8EB" Click="BtnPlayPause_Click"/>
                                    <Rectangle x:Name="PlaySpotlight" RadiusX="34" RadiusY="34" IsHitTestVisible="False" Opacity="0">
                                        <Rectangle.Fill>
                                            <RadialGradientBrush RadiusX="0.7" RadiusY="0.7">
                                                <GradientStop Color="#60FFFFFF" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </Grid>
                                <Grid x:Name="PlayIcon3DLayer" IsHitTestVisible="False">
                                    <materialDesign:PackIcon x:Name="PlayPauseIcon" Kind="Play" Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                        <materialDesign:PackIcon.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform/>
                                                <TranslateTransform/>
                                            </TransformGroup>
                                        </materialDesign:PackIcon.RenderTransform>
                                    </materialDesign:PackIcon>
                                </Grid>
                            </Grid>

                            <Grid x:Name="NextContainer" Width="64" Height="56" Background="Transparent">
                                <Grid x:Name="NextBgLayer">
                                    <Button x:Name="BtnNext" FocusVisualStyle="{x:Null}" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ElevationAssist.Elevation="Dp0" Padding="0" Width="64" Height="56" Margin="0" materialDesign:ButtonAssist.CornerRadius="28" BorderThickness="0" Background="#FF9BC8EB" Click="BtnNext_Click"/>
                                    <Rectangle x:Name="NextSpotlight" RadiusX="28" RadiusY="28" IsHitTestVisible="False" Opacity="0">
                                        <Rectangle.Fill>
                                            <RadialGradientBrush RadiusX="0.7" RadiusY="0.7">
                                                <GradientStop Color="#60FFFFFF" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </Grid>
                                <Grid x:Name="NextIcon3DLayer" IsHitTestVisible="False">
                                    <materialDesign:PackIcon x:Name="NextIcon" Kind="SkipNext" Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                        <materialDesign:PackIcon.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform/>
                                                <TranslateTransform/>
                                            </TransformGroup>
                                        </materialDesign:PackIcon.RenderTransform>
                                    </materialDesign:PackIcon>
                                </Grid>
                            </Grid>

                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </materialDesign:Card>
    </Grid>
</Window>